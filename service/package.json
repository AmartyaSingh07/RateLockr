{
  "name": "ratelockr-service",
  "version": "1.0.0",
  "description": "Highly available, language-agnostic distributed rate-limiting microservice",
  "author": "RateLockr Team",
  "license": "MIT",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --clear src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --verbose --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --verbose",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.17",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
